{% set pageData = i18n.pages[lang] %}
<section id="overview" class="hero section-shell">
  <div class="hero-copy">
    <p class="eyebrow">{{ pageData.hero.kicker }}</p>
    <h1>{{ pageData.hero.heading }}</h1>
    <p class="hero-lead">{{ pageData.hero.lead }}</p>
    <div class="hero-actions" aria-label="{{ pageData.resourcesTitle }}">
      <a class="button button-primary" href="https://app.mathjslab.com/" target="_blank" rel="noopener noreferrer">{{ pageData.hero.primaryCta }}</a>
      <a class="button button-secondary" href="https://github.com/MathJSLab" target="_blank" rel="noopener noreferrer">
        <img class="button-icon" src="/img/Octicons-mark-github.svg" alt="">
        <span>{{ pageData.hero.secondaryCta }}</span>
      </a>
    </div>
    <div class="install-command" aria-label="{{ pageData.hero.installLabel }}">
      <span>
        <img src="/img/Npm-logo.svg" alt="">
        {{ pageData.hero.installLabel }}
      </span>
      <code>npm install mathjslab</code>
    </div>
  </div>
  <div class="hero-panel" aria-label="{{ pageData.hero.terminalTitle }}">
    <div class="terminal-bar">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <pre><code>&gt;&gt; {{ pageData.hero.promptOne }}
{{ pageData.hero.outputOne }}
&gt;&gt; {{ pageData.hero.promptTwo }}
{{ pageData.hero.outputTwo }}</code></pre>
  </div>
</section>

<section id="features" class="section-shell">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.features }}</p>
    <h2>{{ pageData.description }}</h2>
  </div>
  <div class="feature-grid">
    {% for item in pageData.highlights %}
      <article class="feature-card">
        <h3>{{ item.title }}</h3>
        <p>{{ item.text }}</p>
      </article>
    {% endfor %}
  </div>
</section>

<section id="ecosystem" class="section-shell split-section">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.ecosystem }}</p>
    <h2>{{ pageData.ecosystemTitle }}</h2>
    <p>{{ pageData.ecosystemLead }}</p>
  </div>
  <div class="repo-list">
    {% for repo in pageData.repositories %}
      <a class="repo-card" href="{{ repo.href }}" target="_blank" rel="noopener noreferrer">
        <span>
          {% if repo.icon %}
            <img src="{{ repo.icon }}" alt="">
          {% endif %}
          {{ repo.role }}
        </span>
        <strong>{{ repo.name }}</strong>
        <p>{{ repo.text }}</p>
      </a>
    {% endfor %}
  </div>
</section>

<section id="publication" class="section-shell publication-section">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.publication }}</p>
    <h2>{{ pageData.publicationTitle }}</h2>
    <p>{{ pageData.publicationLead }}</p>
  </div>
  <p class="publication-intro">{{ pageData.publicationText }}</p>
  <div class="publication-grid">
    {% for item in pageData.publications %}
      <article class="publication-card">
        <div>
          <span>
            {% if item.icon %}
              <img src="{{ item.icon }}" alt="">
            {% endif %}
            {{ item.role }}
          </span>
          <h3><a href="{{ item.href }}" target="_blank" rel="noopener noreferrer">{{ item.name }}</a></h3>
          <p>{{ item.text }}</p>
        </div>
        <div class="badge-list" aria-label="{{ item.name }} badges">
          {% for badge in item.badges %}
            <a href="{{ badge.href }}" target="_blank" rel="noopener noreferrer">
              <img src="{{ badge.src }}" alt="{{ badge.alt }}">
            </a>
          {% endfor %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<section id="archive" class="section-shell archive-section">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.archive }}</p>
    <h2>{{ pageData.archiveTitle }}</h2>
    <p>{{ pageData.archiveLead }}</p>
  </div>
  <div class="archive-list">
    {% for item in pageData.archiveItems %}
      <a class="archive-card" href="{{ item.href }}" target="_blank" rel="noopener noreferrer">
        <span>{{ item.language }} · {{ item.file }}</span>
        <strong>{{ item.title }}</strong>
        <p>{{ item.description }}</p>
        <small>{{ item.date }}</small>
      </a>
    {% endfor %}
  </div>
</section>

<section id="resources" class="section-shell resources-section">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.resources }}</p>
    <h2>{{ pageData.resourcesTitle }}</h2>
    <p>{{ pageData.resourcesLead }}</p>
  </div>
  <div class="resource-links">
    {% for resource in pageData.resources %}
      <a href="{{ resource.href }}" target="_blank" rel="noopener noreferrer">
        {% if resource.icon %}
          <img src="{{ resource.icon }}" alt="">
        {% endif %}
        <span>{{ resource.label }}</span>
      </a>
    {% endfor %}
  </div>
  <div class="notice-grid">
    <p>{{ pageData.notices.education }}</p>
    <p>{{ pageData.notices.trademark }}</p>
  </div>
</section>

<section id="contact" class="section-shell contact-section">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.contact }}</p>
    <h2>{{ pageData.contactTitle }}</h2>
    <p>{{ pageData.contactLead }}</p>
  </div>
  <a class="contact-card" href="mailto:{{ pageData.notices.contactEmail }}">
    {{ pageData.notices.contactEmail }}
  </a>
</section>

<section id="license" class="section-shell license-section">
  <div class="section-heading">
    <p class="eyebrow">{{ pageData.nav.license }}</p>
    <h2>{{ pageData.licenseTitle }}</h2>
    <p>{{ pageData.licenseLeadPrefix }}<a href="{{ pageData.licenseHref }}" target="_blank" rel="noopener noreferrer">{{ pageData.licenseLinkLabel }}</a>{{ pageData.licenseLeadSuffix }}</p>
  </div>
  <div class="license-panel">
    <div class="license-branding" aria-hidden="true">
      <img src="/img/MIT_Logo_New.svg" alt="">
    </div>
    <pre><code>{{ pageData.licenseText }}</code></pre>
  </div>
</section>
